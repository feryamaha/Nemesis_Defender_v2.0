P ==> ENG["scan_content engine<br/>content + command analysis"]
ENG ==> SEV{"hostile?"}

SEV ==>|"no"| OK["ALLOW<br/>action proceeds"]
SEV ==>|"yes"| BLK["BLOCK<br/>exit 2 · no execution"]

BLK -. "reached disk" .-> DM["LAYER 2 · DAEMON<br/>filesystem watcher"]
DM ==> Q["QUARANTINE<br/>isolate file · no delete"]
Q ==> HUM["human decides<br/>restore or purge"]

ACT -. "Linux · parallel" .-> K["LAYER 3 · eBPF (kernel)<br/>backstop if pretool bypassed"]
K ==> EP["BLOCK in kernel<br/>-EPERM"]

OK ==> LOG["local-only log<br/>nothing leaves the host"]
BLK ==> LOG
EP ==> LOG

