{
  "version": "1.0.0",
  "description": "Configuração de severidade para ast-linters (qualidade). Regras não bloqueam; apenas alertam.",
  "blocking_mode": false,
  "blocking_severity_threshold": "warning",
  "rules": {
    "any_via_alias": "warn",
    "conditional_hooks": "warn",
    "no_floating_promises": "warn",
    "no_console": "warn",
    "jsx_no_target_blank": "warn",
    "no_unsafe_assignment": "warn"
  }
}