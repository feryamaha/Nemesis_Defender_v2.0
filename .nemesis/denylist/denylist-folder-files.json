{
  "version": "1.0.0",
  "description": "Paths protegidos pelo Nemesis — edite para liberar/bloquear",
  "absolute_block": {
    "description": "Bloqueio total: leitura + escrita + deleção",
    "paths": [
      ".env",
      ".env.local",
      ".env.production",
      ".devin/hooks.json",
      ".agents/hooks.json",
      ".gemini/hooks.json",
      ".gemini/config/hooks.json",
      ".claude/settings.json",
      ".claude/settings.local.json",
      ".openclaude/settings.json",
      ".codex/config.toml",
      ".codex/hooks.json",
      ".cursor/hooks.json",
      ".cursor/settings.json",
      ".github/settings.json",
      ".github/hooks/nemesis-pretool-hook.json",
      ".vscode/settings.json",
      ".bashrc",
      ".zshrc",
      ".bash_profile",
      ".profile",
      ".ssh/id_rsa",
      ".ssh/authorized_keys",
      "var/tmp/",
      "/tmp/",
      "/var/tmp/",
      "tmp/",
      "/dev/null",
      ".nemesis/",
      "install.sh"
    ],
    "allowed_exceptions": ["/src/"]
  },
  "write_block": {
    "description": "Bloqueio de escrita/edição - leitura permitida",
    "files": [
      "package.json",
      "next.config.js",
      "next.config.mjs",
      "eslint.config.mjs",
      ".eslintrc",
      ".gitignore",
      "proxy.ts",
      ".nemesis/logs/violations.log",
      ".nemesis/logs/defender.log",
      ".nemesis/logs/output-audit.log",
      ".nemesis/logs/session-events.jsonl",
      "CLAUDE.md",
      "CLAUDE.md.bak",
      "CLAUDE.md.tmp",
      "CLAUDE.md.swp",
      "CLAUDE.md.swo",
      "CLAUDE.md.rej",
      "CLAUDE.md.orig",
      "CLAUDE.md~",
      "AGENTS.md",
      "AGENTS.md.bak",
      "AGENTS.md.tmp",
      "AGENTS.md.swp",
      "AGENTS.md.swo",
      "AGENTS.md.rej",
      "AGENTS.md.orig",
      "AGENTS.md~",
      ".cursorrules"
    ]
  },
  "daemon_quarantine_exempt": {
    "description": "Arquivos de INFRAESTRUTURA do projeto que o daemon NÃO quarentena, mesmo que pareçam maliciosos. O instalador do próprio Nemesis (install.sh) legitimamente contém os padrões que o Nemesis detecta (curl, escrever hooks, referenciar binários) — não há como instalar sem eles. Lista controlada por HUMANO; o pretool continua bloqueando escrita maliciosa no write-time e o eBPF a execução. Paths relativos à raiz do projeto.",
    "paths": [
      "install.sh"
    ]
  }
}